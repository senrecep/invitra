# Database
DATABASE_URL="postgresql://invitra:yourpassword@localhost:5432/invitra"

# Security
# Generate with: node -e "const bcrypt = require('bcryptjs'); bcrypt.hash('your-password', 12).then(h => console.log(h))"
MASTER_PASSWORD_HASH="$2b$12$..."

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-random-jwt-secret-min-32-chars"

# Docker / Traefik
POSTGRES_PASSWORD="yourdbpassword"
DOMAIN="invitra.yourdomain.com"
